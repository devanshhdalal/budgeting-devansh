# Savvr - copy to .env and fill in real values (never commit .env)

# Website: shared key + x-budget-user header (set in UserSwitcher)
API_KEY=your-shared-web-key
VITE_API_KEY=your-shared-web-key

# Apple Shortcuts: one key per person (no x-budget-user header)
API_KEY_DEVANSH=devansh-shortcut-key
API_KEY_PAULA=paula-shortcut-key

# Server
# PORT=3000
# DEBUG_SHORTCUT=1

# Optional GitHub sync
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_REPO=
# GITHUB_BRANCH=main
